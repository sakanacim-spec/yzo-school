# =========================================
# SaaS Platform — Variables d'Environnement
# =========================================
# Copier ce fichier en apps/api/.env et remplir les valeurs

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── Supabase SaaS Platform ──────────────────────────────────────────────────
# MVP : pointer vers le projet Supabase existant de Yziow
# Production séparée : remplacer par les credentials du projet SaaS dédié
# → AUCUNE modification de code nécessaire, uniquement ces 3 variables
SAAS_SUPABASE_URL=https://your-project.supabase.co
SAAS_SUPABASE_ANON_KEY=your-anon-key
SAAS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase Fallback (si SAAS_SUPABASE_* non définis) ─────────────────────
# Ces variables servent de fallback ET pour Supabase Auth (login/signup)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.eu

# ── SMS (Twilio — optionnel) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Reset Password ────────────────────────────────────────────────────────────
RESET_PASSWORD_URL=http://localhost:3001/reset-password

# ════════════════════════════════════════════════════════════════════════════════
# GUIDE DE SÉPARATION (quand Yziow passe en production à grande échelle)
# ════════════════════════════════════════════════════════════════════════════════
#
# 1. Créer un nouveau projet Supabase dédié au SaaS
# 2. Exporter les tables saas_* depuis le projet Yziow
# 3. Importer dans le nouveau projet
# 4. Mettre à jour UNIQUEMENT les 3 variables SAAS_SUPABASE_* ci-dessus
# 5. Redéployer → séparation complète, aucune réécriture de code
#
# Les tables saas_* restent dans le projet Yziow tant que SAAS_SUPABASE_URL
# pointe vers lui. Dès qu'on change l'URL, tout bascule automatiquement.
# ════════════════════════════════════════════════════════════════════════════════
