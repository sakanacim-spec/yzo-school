{
  "name": "@saas/api",
  "version": "0.0.1",
  "description": "SaaS Platform — API NestJS (Gateway + Modules métier)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@fastify/helmet": "^11.1.1",
    "@fastify/static": "^6.12.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@saas/types": "workspace:*",
    "@saas/utils": "workspace:*",
    "@saas/validators": "workspace:*",
    "@sentry/nestjs": "^10.65.0",
    "@sentry/node": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-i18n": "^10.8.5",
    "nestjs-pino": "^4.6.1",
    "openai": "^6.46.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^3.4.0",
    "rxjs": "^7.8.1",
    "stripe": "^22.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "jest": "^29.5.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
